# =======================================
# Banco de Dados (PostgreSQL)
# =======================================
POSTGRES_DB=flowcarreiras
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# =======================================
# Backend (Spring Boot)
# =======================================
# Gere um secret forte para produção (mínimo 256 bits em base64)
JWT_SECRET=Zmxvd2NhcnJlaXJhcy1zZWNyZXQta2V5LWZvci1qd3QtdG9rZW5zLTI1NmJpdA==

# Senha do usuário de teste criado no seed
SEED_PASSWORD=senha123
SIM_USERS=400
FRONTEND_PORT=80

# =======================================
# Frontend (usado em dev com servidor Vite)
# =======================================
# Em produção Docker não é necessário — o Nginx faz o proxy /api → backend
VITE_API_URL=http://localhost:8080
