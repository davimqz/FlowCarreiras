FROM python:3.12-slim

WORKDIR /app

COPY dashboard/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY dashboard/.streamlit/ .streamlit/
COPY dashboard/app.py .
COPY dashboard/lib/ lib/
COPY scripts/ /seed-scripts/

EXPOSE 10000

CMD ["sh", "-c", "python /seed-scripts/setup_demo_prod.py && exec streamlit run app.py --server.port=${PORT:-8501}"]
